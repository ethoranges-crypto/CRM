# ─── Turso Database (required) ───────────────────────────────────────────────
# Get these from https://turso.tech after creating a free database
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Access Control (required) ────────────────────────────────────────────────
# A secret token for edit access. Keep this private.
# Share your app URL with ?edit=YOUR_TOKEN_HERE to unlock edit mode.
# After visiting that URL once, edit mode is saved in a cookie for 1 year.
EDIT_TOKEN=change-me-to-a-long-random-secret

# ─── Telegram Integration (optional) ─────────────────────────────────────────
# Get API_ID and API_HASH from https://my.telegram.org
# TG_SESSION is generated after logging in via the /telegram/auth page
TG_API_ID=0
TG_API_HASH=your-telegram-api-hash
TG_SESSION=your-telegram-session-string
